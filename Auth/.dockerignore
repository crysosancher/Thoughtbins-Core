# ==============================================================================
# Docker ignore file - exclude unnecessary files from build context
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
*.egg-info/
*.egg
dist/
build/
*.whl

# Virtual environments
.venv
venv
env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git
.gitignore

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Docker (don't need these in the image)
docker-compose*.yml
Dockerfile*
.dockerignore

# Documentation
*.md
docs/

# Local development files
.env.local
.env.development
.env.example

# Logs
*.log
logs/

# OS files
.DS_Store
Thumbs.db