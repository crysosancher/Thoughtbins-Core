# ============================================================================
# Auth API Configuration
# ============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit real .env files with credentials.

# --- App Setup ---------------------------------------------------------------
APP_NAME=Auth API
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ----------------------------------------------------------------
# PostgreSQL connection string.
# Special characters in passwords MUST be URL-encoded:
#   @ -> %40
#   : -> %3A
#   / -> %2F
#   # -> %23
#   ? -> %3F
#   % -> %25
# Example: password "Pass@123" becomes "Pass%40123"
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

# --- JWT -----------------------------------------------------------------------
# Generate new secrets for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Use different secrets for access and refresh tokens.
JWT_SECRET_KEY=your-access-secret-key-min-32-bytes
JWT_REFRESH_SECRET_KEY=your-refresh-secret-key-min-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS & Security ----------------------------------------------------------
# Allowed origins (comma-separated). Use "*" to allow all (dev only).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Trusted hosts (comma-separated). Use "*" to allow all.
TRUSTED_HOSTS=localhost,127.0.0.1

# --- Bcrypt ------------------------------------------------------------------
# Cost factor for password hashing (4-16). Higher = slower, more secure.
# Use 12+ for production.
BCRYPT_ROUNDS=12

# --- Rate Limiting ---------------------------------------------------------------
# Per-IP request limits. Format: "requests/time_window"
# Examples: "100/minute", "1000/hour"
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_REGISTER=10/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_VERIFY=60/minute